{
  "name": "tumbador-kahoot",
  "productName": "TUMBADOR DE KAHOOT (Kahoot Hacks)",
  "version": "1.0.0",
  "description": "Herramienta para lanzar bots en Kahoot: entrar bots, ultra ataque y logs.",
  "type": "commonjs",
  "main": "electron.js",
  "scripts": {
    "bot": "node bot.js",
    "bots": "node bots.js",
    "web": "node server.js",
    "start": "node bot.js",
    "electron": "electron .",
    "build-icon": "node build-icon.js",
    "build": "npm run build-icon && electron-builder --win portable",
    "dist": "npm run build-icon && electron-builder --win portable"
  },
  "dependencies": {
    "express": "^4.18.2",
    "kahoot.js-latest": "^1.0.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "sharp": "^0.33.0",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.tumbador.kahoot",
    "productName": "TUMBADOR DE KAHOOT (Kahoot Hacks)",
    "directories": { "output": "dist" },
    "files": [
      "electron.js",
      "server.js",
      "runBots.js",
      "build-icon.js",
      "icon.ico",
      "icono.png",
      "public/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "TUMBADOR-Kahoot-Hacks-${version}.exe"
    }
  }
}
