{
  "name": "tumbador-kahoot",
  "productName": "TUMBADOR DE KAHOOT (Kahoot Hacks)",
  "version": "1.0.0",
  "description": "Herramienta para lanzar bots en Kahoot: entrar bots, ultra ataque y logs.",
  "type": "commonjs",
  "main": "electron.js",
  "scripts": {
    "bot": "node bot.js",
    "bots": "node bots.js",
    "web": "node server.js",
    "start": "node bot.js",
    "electron": "electron .",
    "build-icon": "node build-icon.js",
    "build": "node build-server.js",
    "build:electron": "electron-builder --win portable",
    "dist": "node build-server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "kahoot.js-latest": "^1.0.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "pkg": "^5.8.1",
    "sharp": "^0.33.0",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.tumbador.kahoot",
    "productName": "TUMBADOR DE KAHOOT (Kahoot Hacks)",
    "directories": { "output": "dist" },
    "asar": false,
    "files": [
      "electron.js",
      "server.js",
      "runBots.js",
      "public/**/*",
      "node_modules/**/*",
      "icono.png"
    ],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "icono.png"
    },
    "portable": {
      "artifactName": "TUMBADOR-Kahoot-Hacks-${version}.exe"
    }
  }
}
